<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:title="@string/config_category_view">
    <androidx.preference.CheckBoxPreference
        android:title="@string/config_iconbutton_title"
        android:key="@string/config_showIcons_key"
        android:summary="@string/config_iconbutton_summary"
        android:defaultValue="true" />
    <androidx.preference.CheckBoxPreference
        android:title="@string/config_showWayIcons_title"
        android:key="@string/config_showWayIcons_key"
        android:summary="@string/config_showWayIcons_summary"
        android:defaultValue="true" />
    <androidx.preference.CheckBoxPreference
        android:defaultValue="true"
        android:key="@string/config_tagFormEnabled_key"
        android:summary="@string/config_tagFormEnabled_summary"
        android:title="@string/config_tagFormEnabled_title" />
    <androidx.preference.CheckBoxPreference
        android:defaultValue="true"
        android:key="@string/config_supportPresetLabels_key"
        android:summary="@string/config_supportPresetLabels_summary"
        android:title="@string/config_supportPresetLabels_title" />
    <androidx.preference.ListPreference
        android:defaultValue="@string/follow_GPS_left"
        android:entries="@array/followGPSbutton_entries"
        android:entryValues="@array/followGPSbutton_values"
        android:key="@string/config_followGPSbutton_key"
        android:summary="@string/config_followGPSbutton_summary"
        android:title="@string/config_followGPSbutton_title" />
    <androidx.preference.CheckBoxPreference
        android:defaultValue="false"
        android:key="@string/config_alwaysDrawBoundingBoxes_key"
        android:summary="@string/config_alwaysDrawBoundingBoxes_summary"
        android:title="@string/config_alwaysDrawBoundingBoxes_title" />
    <androidx.preference.ListPreference
        android:defaultValue="@string/map_orientation_auto"
        android:entries="@array/map_orientation_entries"
        android:entryValues="@array/map_orientation_values"
        android:key="@string/config_mapOrientation_key"
        android:summary="@string/config_map_orientation_summary"
        android:title="@string/config_map_orientation_title" />
    <androidx.preference.CheckBoxPreference
        android:defaultValue="true"
        android:key="@string/config_showTolerance_key"
        android:summary="@string/config_showTolerance_summary"
        android:title="@string/config_showTolerance_title" />
    <androidx.preference.CheckBoxPreference
        android:defaultValue="false"
        android:key="@string/config_use_back_for_undo_key"
        android:summary="@string/config_use_back_for_undo_summary"
        android:title="@string/config_use_back_for_undo_title" />
    <androidx.preference.ListPreference
        android:defaultValue="@string/theme_follow"
        android:entries="@array/theme_entries"
        android:entryValues="@array/theme_values"
        android:key="@string/config_theme_key"
        android:summary="@string/config_theme_summary"
        android:title="@string/config_theme_title" />
    <androidx.preference.CheckBoxPreference
        android:defaultValue="true"
        android:key="@string/config_splitActionBarEnabled_key"
        android:summary="@string/config_splitActionBarEnabled_summary"
        android:title="@string/config_splitActionBarEnabled_title" />
    <androidx.preference.ListPreference
        android:key="@string/config_appLocale_key"
        android:title="@string/config_appLocale_title"
        android:summary="@string/config_appLocale_summary"
        android:defaultValue="" />
    <ch.poole.android.numberpickerpreference.NumberPickerPreference
        android:defaultValue="4"
        android:key="@string/config_maxInlineValues_key"
        android:title="@string/config_maxInlineValues_title"
        android:dialogTitle="@string/config_maxInlineValues_title"
        android:numeric="integer" app:spt_maxValue="20"
        app:spt_minValue="1"
        app:spt_currentValueText="@string/config_maxInlineValues_current"
        app:spt_setWrapSelectorWheel="false" />
    <ch.poole.android.numberpickerpreference.NumberPickerPreference
        android:defaultValue="80"
        android:dialogTitle="@string/config_longStringLimit_title"
        android:key="@string/config_longStringLimit_key"
        android:numeric="integer"
        android:summary="@string/config_longStringLimit_summary"
        android:title="@string/config_longStringLimit_title"
        app:spt_maxValue="255" app:spt_minValue="0"
        app:spt_increment="1"
        app:spt_currentValueText="@string/config_longStringLimit_current"
        app:spt_setWrapSelectorWheel="false" />
    <ch.poole.android.numberpickerpreference.NumberPickerPreference
        android:defaultValue="60"
        android:dialogTitle="@string/config_autoLockDelay_title"
        android:key="@string/config_autoLockDelay_key"
        android:numeric="integer"
        android:summary="@string/config_autoLockDelay_summary"
        android:title="@string/config_autoLockDelay_title"
        app:spt_maxValue="300" app:spt_minValue="0"
        app:spt_increment="10"
        app:spt_currentValueText="@string/config_autoLockDelay_current"
        app:spt_setWrapSelectorWheel="false" />
    <androidx.preference.CheckBoxPreference
        android:defaultValue="true"
        android:key="@string/config_enableAntiAliasing_key"
        android:summary="@string/config_enableAntiAliasing_summary"
        android:title="@string/config_enableAntiAliasing_title" />
    <ch.poole.android.numberpickerpreference.NumberPickerPreference
        android:defaultValue="16"
        android:dialogTitle="@string/config_maxStrokeWidth_title"
        android:key="@string/config_maxStrokeWidth_key"
        android:numeric="integer"
        android:summary="@string/config_maxStrokeWidth_summary"
        android:title="@string/config_maxStrokeWidth_title"
        app:spt_maxValue="32" app:spt_minValue="8"
        app:spt_currentValueText="@string/config_maxStrokeWidth_current"
        app:spt_setWrapSelectorWheel="false" />
    <ch.poole.android.numberpickerpreference.NumberPickerPreference
        android:defaultValue="50"
        android:dialogTitle="@string/config_uploadOk_title"
        android:key="@string/config_uploadOk_key"
        android:numeric="integer"
        android:summary="@string/config_uploadOk_summary"
        android:title="@string/config_uploadOk_title"
        app:spt_maxValue="1000" app:spt_minValue="0"
        app:spt_increment="10"
        app:spt_currentValueText="@string/config_upload_current"
        app:spt_setWrapSelectorWheel="false" />
    <ch.poole.android.numberpickerpreference.NumberPickerPreference
        android:defaultValue="200"
        android:dialogTitle="@string/config_uploadWarn_title"
        android:key="@string/config_uploadWarn_key"
        android:numeric="integer"
        android:summary="@string/config_uploadWarn_summary"
        android:title="@string/config_uploadWarn_title"
        app:spt_maxValue="1000" app:spt_minValue="0"
        app:spt_increment="20"
        app:spt_currentValueText="@string/config_upload_current"
        app:spt_setWrapSelectorWheel="false" />
    <ch.poole.android.numberpickerpreference.NumberPickerPreference
        android:defaultValue="6"
        android:dialogTitle="@string/config_uploadChecker_title"
        android:key="@string/config_uploadChecker_key"
        android:numeric="integer"
        android:summary="@string/config_uploadChecker_summary"
        android:title="@string/config_uploadChecker_title"
        app:spt_maxValue="168" app:spt_minValue="1"
        app:spt_increment="1"
        app:spt_currentValueText="@string/config_uploadChecker_current"
        app:spt_setWrapSelectorWheel="false" />
    <ch.poole.android.numberpickerpreference.NumberPickerPreference
        android:defaultValue="50000"
        android:dialogTitle="@string/config_dataWarn_title"
        android:key="@string/config_dataWarn_key"
        android:numeric="integer"
        android:summary="@string/config_dataWarn_summary"
        android:title="@string/config_dataWarn_title"
        app:spt_maxValue="1000000" app:spt_minValue="10000"
        app:spt_increment="10000"
        app:spt_currentValueText="@string/config_upload_current"
        app:spt_setWrapSelectorWheel="false" />
    <androidx.preference.CheckBoxPreference
        android:defaultValue="false"
        android:key="@string/config_useUrlForFeedback_key"
        android:summary="@string/config_useUrlForFeedback_summary"
        android:title="@string/config_useUrlForFeedback_title" />
    <ch.poole.android.numberpickerpreference.NumberPickerPreference
        android:defaultValue="50"
        android:dialogTitle="@string/config_beepVolume_title"
        android:key="@string/config_beepVolume_key"
        android:numeric="integer"
        android:summary="@string/config_beepVolume_summary"
        android:title="@string/config_beepVolume_title"
        app:spt_maxValue="100" app:spt_minValue="0"
        app:spt_increment="1"
        app:spt_currentValueText="@string/config_beepVolume_current"
        app:spt_setWrapSelectorWheel="false" />
    <ch.poole.android.numberpickerpreference.NumberPickerPreference
        android:defaultValue="16"
        android:dialogTitle="@string/config_mapillary_min_zoom_title"
        android:key="@string/config_mapillary_min_zoom_key"
        android:numeric="integer"
        android:summary="@string/config_mapillary_min_zoom_summary"
        android:title="@string/config_mapillary_min_zoom_title"
        app:spt_maxValue="20" app:spt_minValue="0"
        app:spt_increment="1"
        app:spt_currentValueText="@string/config_mapillary_min_zoom_current"
        app:spt_setWrapSelectorWheel="false" />
    <androidx.preference.ListPreference
        android:defaultValue="1"
        android:entries="@array/name_cap_entries"
        android:entryValues="@array/name_cap_values"
        android:key="@string/config_nameCap_key"
        android:summary="@string/config_nameCap_summary"
        android:title="@string/config_nameCap_title" />
    <androidx.preference.CheckBoxPreference
        android:title="@string/config_zoomWithKeys_title"
        android:key="@string/config_zoomWithKeys_key"
        android:summary="@string/config_zoomWithKeys_summary"
        android:defaultValue="false" />
    <androidx.preference.Preference
        android:title="@string/config_keyboard_shortcuts_title"
        android:key="@string/config_keyboard_shortcuts_key"
        android:summary="@string/config_keyboard_shortcuts_summary" />
</PreferenceScreen>
